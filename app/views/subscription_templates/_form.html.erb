<%= error_messages_for 'subscription_template' %>

<%
  # Progressive disclosure (#66): the always-visible basics cover the happy
  # path ("when an entity of type X changes, open an issue in tracker Y");
  # everything else lives in collapsible sections. Sections are collapsed on a
  # new template and auto-expanded on edit when they contain values.
  template = @subscription_template
  filters_expanded = template.persisted? &&
                     (template.attrs.present? || template.expression_query.present? ||
                      template.expression_georel.present?)
  issue_details_expanded = template.persisted?
  subscription_options_expanded = template.persisted? &&
                                  (template.subscription_id.present? || template.expires.present? ||
                                   template.comment.present? || template.context.present?)
%>

<%= render partial: 'subscription_templates/form_basics', locals: { f: f } %>

<%= render partial: 'subscription_templates/form_section',
           locals: { section: 'filters', expanded: filters_expanded,
                     label: l(:gtt_fiware_form_section_filters), f: f } %>

<%= render partial: 'subscription_templates/form_section',
           locals: { section: 'issue_details', expanded: issue_details_expanded,
                     label: l(:gtt_fiware_form_section_issue_details), f: f } %>

<%= render partial: 'subscription_templates/form_section',
           locals: { section: 'subscription_options', expanded: subscription_options_expanded,
                     label: l(:gtt_fiware_form_section_subscription_options), f: f } %>

<%= render partial: 'subscription_templates/form_script' %>

<%= wikitoolbar_for 'subscription_template_description' %>
<%= wikitoolbar_for 'subscription_template_notes' %>
